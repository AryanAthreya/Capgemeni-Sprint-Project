# =============================================================
# Azure OpenAI Configuration
# =============================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# =============================================================
# Azure AI Search (Vector Store)
# =============================================================
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-key-here
AZURE_SEARCH_INDEX_NAME=medical-knowledge

# =============================================================
# Azure CosmosDB (NoSQL Database)
# =============================================================
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-key-here
COSMOS_DATABASE=healthcare_db
COSMOS_CONTAINER=patients

# =============================================================
# Azure Blob Storage (Data Pipeline)
# =============================================================
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey==;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=healthcare-data

# =============================================================
# Azure Key Vault (Optional, for Production)
# =============================================================
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net/

# =============================================================
# Azure Data Factory (Pipeline Orchestration)
# =============================================================
ADF_SUBSCRIPTION_ID=your-subscription-id
ADF_RESOURCE_GROUP=your-resource-group-name
ADF_FACTORY_NAME=your-adf-factory-name
ADF_PIPELINE_NAME=healthcare-ingest-pipeline

# =============================================================
# Application Settings
# =============================================================
APP_ENV=development
LOG_LEVEL=INFO
MODEL_PATH=models/model.pkl
LABEL_ENCODER_PATH=models/label_encoder.pkl
